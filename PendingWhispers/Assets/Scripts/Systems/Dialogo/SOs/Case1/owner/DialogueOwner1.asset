    neutral: {fileID: 3652085389764901965, guid: 8142a1ff8408e2c4189efa114d997a6e, type: 3}
    happy: {fileID: 0}
    sad: {fileID: 0}
    angry: {fileID: -8236101453732318523, guid: 8142a1ff8408e2c4189efa114d997a6e, type: 3}
