  - id: butler
    displayName: "Desir\xE9e Cahu\xE8te"
    portrait: {fileID: 21300000, guid: 1d364f4b642932d40adc9cecbfeb71f5, type: 3}
    isLeftSide: 0
    neutral: {fileID: 21300000, guid: 1d364f4b642932d40adc9cecbfeb71f5, type: 3}
    happy: {fileID: 21300000, guid: 6bd6f33d70437744fad8b2ac2c71ba16, type: 3}
    sad: {fileID: 21300000, guid: 0e6fc337674431141907fae9306fa81a, type: 3}
