      endsDialogue: 0
    requiredFlags: []
    onEnterFlags: []
    onEnterEvents: []
    isImportantLine: 0
    expression: 0
  - id: 2
    speakerID: ghost1
    text: "Oh? Is that so? All of these years I've hold on to these grudge against
      the world who silenced me, when I was the one who didn't listen to others...
      how... sad... \n\n"
    nextNodeID: 
    choices:
    - text: 'See you Vivienne '
