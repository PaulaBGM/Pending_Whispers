    onEnterEvents: []
    isImportantLine: 0
    expression: 0
  - id: 1
    speakerID: ghost1
    text: Really? You found out who was the murderous fiend? The one who tried to
      quiet my magnificent voice?
    nextNodeID: 
    choices:
    - text: No one murdered you... you suffered an accident, and died because of
        an allergy reaction
      nextNodeID: 2
      addFlags: []
      requiredFlags:
      - {fileID: 11400000, guid: 8c9823eacec837c4299e0acca9e31dad, type: 2}
      requiredReputation: 0
      reputationChange: 0
      onSelectedEvent: {fileID: 0}
      endsDialogue: 0
    - text: They murdered you because they wanted your precious necklace
      nextNodeID: 3
      addFlags: []
      requiredFlags:
      - {fileID: 11400000, guid: 62256de666409794a87f3313daea52e4, type: 2}
      requiredReputation: 0
