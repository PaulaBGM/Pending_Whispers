  characters:
  - id: Lyra
    displayName: Lyra
    sprite: {fileID: 2916416985251425419, guid: 5d81eb40a54230e4ba26665eb0b757d6, type: 3}
    portrait: {fileID: -6159030981858838909, guid: ac86a53648c7c574986ea53d7179d5c8, type: 3}
    isLeftSide: 1
  - id: ghost1
    displayName: Vivienne Encore
    sprite: {fileID: -6393559205685776795, guid: 7af75cd6ca4e87e42a37e2e3ed3946b2, type: 3}
    portrait: {fileID: -6159030981858838909, guid: ac86a53648c7c574986ea53d7179d5c8, type: 3}
    isLeftSide: 0
  nodes:
  - id: start
    speakerID: ghost1
    text: Another visitor? Another rat hungry for stories?
    nextNodeID: start
    choices:
    - text: I'll talk to you later
      nextNodeID: 
      addFlags: []
      requiredFlags: []
      endsDialogue: 1
    - text: Excu-
      nextNodeID: 1
      addFlags: []
      requiredFlags: []
      endsDialogue: 0
    requiredFlags: []
    onEnterFlags:
    - {fileID: 11400000, guid: 9cc3d14b9dc651b4c8d197dcd5f6c5b9, type: 2}
    onEnterEvents:
    - {fileID: 11400000, guid: ee5cb3d4be5031e4d81e444a4be87cb4, type: 2}
    isImportantLine: 0
  - id: 1
    speakerID: ghost1
    text: GET OUT OF MY HOUSE!
    nextNodeID: 1
    choices:
    - text: "I\u2019m not here for the museum. I came to help."
      nextNodeID: 2
      addFlags: []
      requiredFlags: []
      endsDialogue: 0
    requiredFlags: []
    onEnterFlags: []
    onEnterEvents: []
    isImportantLine: 0
  - id: 2
    speakerID: ghost1
    text: Help?
    nextNodeID: 3
    choices: []
    requiredFlags: []
    onEnterFlags: []
    onEnterEvents: []
    isImportantLine: 0
  - id: 3
    speakerID: ghost1
    text: "They all say that. Then they steal pieces of me. My dresses\u2026 my jewels\u2026
      my songs\u2026 They didn\u2019t even let my bones rest."
    nextNodeID: 4
    choices: []
    requiredFlags: []
    onEnterFlags:
    - {fileID: 11400000, guid: 9cc3d14b9dc651b4c8d197dcd5f6c5b9, type: 2}
    onEnterEvents:
    - {fileID: 11400000, guid: ee5cb3d4be5031e4d81e444a4be87cb4, type: 2}
    isImportantLine: 0
  - id: 4
    speakerID: ghost1
    text: "I didn\u2019t hurt them\u2026 not at first. But I hear them every night.
      Whispers. Laughter. Just like at that party. All of them watching me\u2026
      waiting to see me fall."
    nextNodeID: 4
    choices:
    - text: Who?
      nextNodeID: 5
      addFlags: []
      requiredFlags: []
      endsDialogue: 0
    requiredFlags: []
    onEnterFlags: []
    onEnterEvents: []
    isImportantLine: 0
  - id: 5
    speakerID: ghost1
    text: "EVERYONE. My lover\u2026 Laurent\u2026 My butler\u2026 The guests\u2026
      They all wanted to get rid of me."
    nextNodeID: 5
    choices:
    - text: Why would you think that?
      nextNodeID: 6
      addFlags: []
      requiredFlags: []
      endsDialogue: 0
    requiredFlags: []
    onEnterFlags: []
    onEnterEvents: []
    isImportantLine: 1
  - id: 6
    speakerID: ghost1
    text: Because I saw it in their eyes. Because they stopped applauding when I
      became ill. Because my voice was worth more than my life.
    nextNodeID: 7
    choices: []
    requiredFlags: []
    onEnterFlags: []
    onEnterEvents: []
    isImportantLine: 0
  - id: 7
    speakerID: ghost1
    text: 'And now they desecrate my home to sell memories!

'
    nextNodeID: 8
    choices: []
    requiredFlags: []
    onEnterFlags:
    - {fileID: 11400000, guid: 9cc3d14b9dc651b4c8d197dcd5f6c5b9, type: 2}
    onEnterEvents:
    - {fileID: 11400000, guid: ee5cb3d4be5031e4d81e444a4be87cb4, type: 2}
    isImportantLine: 0
  - id: 8
    speakerID: ghost1
    text: THEY WILL NEVER KNOW PEACE!
    nextNodeID: 
    choices: []
    requiredFlags: []
    onEnterFlags:
    - {fileID: 11400000, guid: 9cc3d14b9dc651b4c8d197dcd5f6c5b9, type: 2}
    onEnterEvents:
    - {fileID: 11400000, guid: ee5cb3d4be5031e4d81e444a4be87cb4, type: 2}
    isImportantLine: 0
