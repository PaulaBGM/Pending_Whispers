  nodes:
  - id: start
    speakerID: ghost1
    text: "\u2026mmm\u2026 la\u2026 la-la\u2026"
    nextNodeID: 1
    choices:
    - text: "That humming\u2026 was that you?"
      nextNodeID: 1
      addFlags: []
      requiredFlags: []
      endsDialogue: 0
    - text: I'm not interested in talking with you
      nextNodeID: 
      addFlags: []
      requiredFlags: []
      endsDialogue: 1
    requiredFlags: []
    onEnterFlags: []
    onEnterEvents: []
    isImportantLine: 0
  - id: 1
    speakerID: ghost1
    text: "It used to be everything.\nMy voice\u2026 my legacy\u2026I once had it
      all. "
    nextNodeID: 2
    choices: []
    requiredFlags: []
    onEnterFlags: []
    onEnterEvents: []
    isImportantLine: 0
  - id: 2
    speakerID: Lyra
    text: Do you remember what happened to you?
    nextNodeID: 3
    choices: []
    requiredFlags: []
    onEnterFlags: []
    onEnterEvents: []
    isImportantLine: 0
  - id: 3
    speakerID: ghost1
    text: Someone... they MURDERED ME! They were jealous of my fame, my wealth, my
      singing prowess...
    nextNodeID: 3
    choices:
    - text: I'm a ghost detective, I can help you out, my name's Lyra
      nextNodeID: 4
      addFlags: []
      requiredFlags: []
      endsDialogue: 0
    - text: 'Good luck with that. '
      nextNodeID: 
      addFlags: []
      requiredFlags: []
      endsDialogue: 1
    requiredFlags: []
    onEnterFlags: []
    onEnterEvents: []
    isImportantLine: 1
  - id: 4
    speakerID: ghost1
    text: I would appreciate it, young one, I'll tell you where you should go
    nextNodeID: 
